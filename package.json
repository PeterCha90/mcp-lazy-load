{
  "name": "mcp-lazy",
  "version": "0.1.7",
  "description": "MCP lazy loading proxy for AI agents - reduce context window token usage by 90%+",
  "type": "module",
  "bin": {
    "mcp-lazy": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist",
    "docs",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "keywords": [
    "mcp",
    "lazy-loading",
    "proxy",
    "ai-agent",
    "cursor"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/PeterCha90/mcp-lazy.git"
  },
  "homepage": "https://github.com/PeterCha90/mcp-lazy#readme",
  "bugs": {
    "url": "https://github.com/PeterCha90/mcp-lazy/issues"
  },
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "commander": "^13.1.0",
    "mcp-lazy": "^0.1.6",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
